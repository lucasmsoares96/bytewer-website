# Postgres connection string. Local dev uses the docker-compose Postgres.
# On Vercel, set DATABASE_URL from the Vercel Postgres / Neon integration's POSTGRES_URL.
DATABASE_URL=postgresql://127.0.0.1:5432/your-database-name

# Used to encrypt JWT tokens
PAYLOAD_SECRET=YOUR_SECRET_HERE

# Used to configure CORS, format links and more. No trailing slash
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Secret used to authenticate cron jobs (Vercel Cron sends `Authorization: Bearer ${CRON_SECRET}`)
CRON_SECRET=YOUR_CRON_SECRET_HERE

# Used to validate preview requests
PREVIEW_SECRET=YOUR_SECRET_HERE

# Vercel Blob storage token (provided by the Vercel Blob integration in production).
# Leave empty in local dev to fall back to local filesystem uploads.
BLOB_READ_WRITE_TOKEN=
